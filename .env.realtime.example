# No API key is required.

# Local Ollama chat model used only to word the grounded MOSAIC result naturally.
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Local faster-whisper speech recognition.
# For English ReDial conversations, base.en is a good CPU starting point.
# For multilingual speech, use small and set STT_LANGUAGE=auto.
STT_MODEL=base.en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
